{
  "name": "@f2b/sandbox",
  "version": "0.1.0",
  "private": true,
  "description": "灵境云 AI 沙箱产品微服务",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "migrate": "tsx src/db/migrate.ts",
    "typecheck": "tsc --noEmit",
    "smoke": "tsx scripts/smoke.ts",
    "smoke:auth": "tsx scripts/smoke-auth.ts",
    "smoke:stream": "tsx scripts/smoke-stream.ts",
    "smoke:cube": "tsx scripts/smoke-cube.ts",
    "smoke:capacity": "tsx scripts/smoke-capacity.ts",
    "smoke:usage": "tsx scripts/smoke-usage.ts",
    "smoke:timeout": "tsx scripts/smoke-timeout.ts",
    "smoke:templates": "tsx scripts/smoke-templates.ts",
    "smoke:pause": "tsx scripts/smoke-pause.ts",
    "smoke:meta": "tsx scripts/smoke-meta.ts",
    "smoke:files-delete": "tsx scripts/smoke-files-delete.ts",
    "smoke:list-filter": "tsx scripts/smoke-list-filter.ts",
    "mock:cube": "tsx scripts/mock-cube-envd.ts",
    "ci:contract": "bash scripts/ci-contract.sh",
    "docker:build": "docker build -f Dockerfile -t ghcr.io/f2b-dev/sandbox:local .."
  },
  "dependencies": {
    "@f2b/spec": "file:../f2b-spec",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.20.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=22"
  },
  "license": "Apache-2.0"
}
