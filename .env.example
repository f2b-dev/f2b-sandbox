PORT=8787
HOST=0.0.0.0
DATABASE_URL=file:./data/f2b-sandbox.db
F2B_SANDBOX_BACKEND=fake

# off（默认，本地/BFF 内网）| api_key（公网 SDK 直连）
F2B_AUTH_MODE=off

# 单机并发 hard cap（running+provisioning+paused）。未设置或 ≤0 = 不限制。
# 对齐 capacity 文档：低配入门 2 / 推荐入门 5 / 单机生产 12
# F2B_MAX_CONCURRENT_SANDBOXES=5

# 管理 API Key 创建/列表/吊销；auth=api_key 时必填
# F2B_ADMIN_TOKEN=change-me-admin

# ——— 生产数据面（仅服务端；勿写入浏览器 / 客户端包）———
# 配置 F2B_CUBE_API_URL 后 createSandboxBackend 自动切 Cube + envd；
# 强制 fake：F2B_SANDBOX_BACKEND=fake
# F2B_CUBE_API_URL=https://cube-api.example
# F2B_CUBE_API_TOKEN=
# 兼容别名：CUBE_API_URL / CUBE_API_TOKEN / CUBE_API_KEY
#
# envd 默认解析为 {port}-{sandboxID}.{domain}；联调 mock 可覆盖基址：
# F2B_CUBE_ENVD_BASE_URL=http://127.0.0.1:18992
# F2B_CUBE_SANDBOX_DOMAIN=cube.app
# F2B_CUBE_ENVD_PORT=49983
# F2B_CUBE_PROXY_SCHEME=http
